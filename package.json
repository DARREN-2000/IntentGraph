{
  "name": "intentgraph",
  "version": "0.1.0",
  "description": "A universal action OS that compiles natural-language intent into trusted workflows",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev": "turbo run dev",
    "cli": "npm run --workspace @intentgraph/cli cli --",
    "cli:build": "npm run --workspace @intentgraph/cli build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "prettier": "^3.1.0",
    "turbo": "^1.11.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
